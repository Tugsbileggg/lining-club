# ──────────────────────────────────────────────────────────────
# Lining Club — environment variables
# Copy to .env.local and fill in. NEVER commit real values.
# ──────────────────────────────────────────────────────────────

# ── Firebase Web SDK (client, admin auth UI) ──
# Firebase Console → Project settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only — privileged) ──
# Firebase Console → Project settings → Service accounts → Generate new private key
# Paste the full JSON as a single line, OR set FIREBASE_SERVICE_ACCOUNT_PATH.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal \n sequences from the JSON; they are normalized at runtime.
FIREBASE_PRIVATE_KEY=
# Optional alternative: absolute path to serviceAccountKey.json (local dev)
# FIREBASE_SERVICE_ACCOUNT_PATH=

# ── App ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=Lining Club

# ── QPay (payment) — TODO: fill when QPay credentials are issued ──
# Obtain from QPay merchant onboarding (https://qpay.mn).
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_CALLBACK_URL=http://localhost:3000/api/payments/qpay/callback

# ── Email ──────────────────────────────────────────────────────
# EMAIL_PROVIDER: "console" logs only (no real send); "resend" delivers via
# the Resend API. To go live: set EMAIL_PROVIDER=resend, add RESEND_API_KEY,
# and set EMAIL_FROM to an address on a domain verified in Resend.
EMAIL_PROVIDER=console
EMAIL_FROM="Lining Club <orders@example.com>"
# RESEND_API_KEY=
# Optional: copy of every new order is emailed here (store owner inbox).
# ORDER_NOTIFY_EMAIL=
